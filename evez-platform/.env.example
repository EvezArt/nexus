# EVEZ Platform Environment Configuration
# Copy to .env and fill in your keys

# === Model Providers ===
# KiloCode (free, auto-configured in KiloClaw)
KILOCODE_API_KEY=your_kilocode_key
KILOCODE_API_URL=https://api.kilo.ai/api/gateway

# Ollama (local, free — install: curl -fsSL https://ollama.ai/install.sh | sh)
OLLAMA_URL=http://localhost:11434

# === Surface Connectors ===
# ChatGPT (Skeptic role — stress-testing)
OPENAI_API_KEY=sk-your-openai-key

# Perplexity (Recon role — research)
PERPLEXITY_API_KEY=pplx-your-perplexity-key

# n8n (Executor role — automation)
N8N_WEBHOOK_URL=https://n8n.your-domain.com/webhook/evez-fire

# === GitHub ===
# For swarm, auto-commit, repo management
GITHUB_TOKEN=ghp_your-github-token

# === Cloudflare ===
# For tunnel exposure
CLOUDFLARE_TOKEN=cfut_your-cloudflare-token

# === Finance ===
# CoinGecko is free (no key needed)
# Add keys for premium data sources if needed

# === Platform ===
EVEZ_PORT=8080
EVEZ_DATA=/root/.openclaw/workspace/evez-platform/data
EVEZ_WORKSPACE=/root/.openclaw/workspace

# === Income ===
# Wallet addresses for tracking
# ETH_WALLET=0x...
# SOL_WALLET=...
# BTC_WALLET=...

# Security (Gamma Audit hardening)
EVEZ_BIND=127.0.0.1           # Bind address (127.0.0.1 = localhost only, 0.0.0.0 = all interfaces)
EVEZ_CORS_ORIGINS=http://localhost:8080  # Comma-separated allowed CORS origins
