# EVEZ Terminal Surface Configuration
# Runtime overrides for trunk-and-branch automation

# Execution
LATENCY_THRESHOLD_MS=20
EXECUTION_MODE=TRUNK_BRANCH_AUTOMATION
RULE_2_REFUSAL_ENABLED=true
HUMAN_APPROVAL_MODE=BOUNDARY_ONLY

# Provenance
PROVENANCE_LOGGING=STRICT
AUTO_BRANCH_RETURN=true
AUTO_SUMMARY_INTERVAL=4
LEDGER_SYNC_INTERVAL_MS=500

# Surface Roles
SURFACE_CLAUDE_ROLE=architect
SURFACE_CHATGPT_ROLE=skeptic
SURFACE_PERPLEXITY_ROLE=recon
SURFACE_OPERATOR_ROLE=executor

# Platform
EVEZ_PORT=8080
EVEZ_DATA=/root/.openclaw/workspace/evez-platform/data
EVEZ_WORKSPACE=/root/.openclaw/workspace

# Income
DAILY_TARGET_USD=100
